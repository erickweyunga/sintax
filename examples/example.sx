use "std/math"
use "std/json"
use "std/string"

fn () example:
    result = math/sqrt(16)
    >> result

fn () json_example:
    json_var = '{"name": "John", "age": 30}'
    data = json/parse(json_var)
    >> json/pretty(data)

fn (str name) str greet:
    return "HELLO, " + string/upper(name)

example()
json_example()
>> greet("John")
