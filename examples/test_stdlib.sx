-- Tests for stdlib modules via proper imports

use "std/string"
use "std/list"
use "std/dict"
use "std/os"

-- === std/string ===

-- test: string/trim("  hello  ") == "hello"
-- test: string/index_of("hello world", "world") == 6
-- test: string/index_of("hello", "xyz") == -1
-- test: string/slice("hello", 1, 4) == "ell"
-- test: string/slice("hello", -3, -1) == "ll"
-- test: string/char_code("A") == 65
-- test: string/from_char_code(65) == "A"
-- test: string/reverse("abc") == "cba"
-- test: string/repeat("ha", 3) == "hahaha"
-- test: string/starts_with("hello", "hel") == true
-- test: string/starts_with("hello", "xyz") == false
-- test: string/ends_with("hello", "llo") == true
-- test: string/contains("hello world", "world") == true
-- test: string/upper("hello") == "HELLO"
-- test: string/lower("HELLO") == "hello"
-- test: string/join(["a", "b", "c"], ", ") == "a, b, c"
-- test: string/length("hello") == 5

-- === std/list ===

-- test: list/index_of([10, 20, 30], 20) == 1
-- test: list/index_of([10, 20, 30], 99) == -1
-- test: list/contains([1, 2, 3], 2) == true
-- test: list/contains([1, 2, 3], 9) == false

fn () bool test_list_ops:
    items = list/concat([1, 2], [3, 4])
    return len(items) == 4 and items[0] == 1 and items[3] == 4
-- test: test_list_ops() == true

fn () bool test_list_slice:
    items = list/slice([1, 2, 3, 4, 5], 1, 3)
    return len(items) == 2 and items[0] == 2 and items[1] == 3
-- test: test_list_slice() == true

fn () bool test_list_insert:
    items = [1, 3]
    list/insert(items, 1, 2)
    return items[1] == 2 and len(items) == 3
-- test: test_list_insert() == true

fn () bool test_list_reverse:
    items = [3, 2, 1]
    list/reverse(items)
    return items[0] == 1 and items[2] == 3
-- test: test_list_reverse() == true

fn () bool test_list_sort:
    items = [3, 1, 2]
    list/sort(items)
    return items[0] == 1 and items[1] == 2 and items[2] == 3
-- test: test_list_sort() == true

fn () bool test_filled:
    items = list/filled(3, 0)
    return len(items) == 3 and items[0] == 0 and items[2] == 0
-- test: test_filled() == true

fn () bool test_unique:
    items = list/unique([1, 2, 2, 3, 1, 3])
    return len(items) == 3
-- test: test_unique() == true

fn () bool test_first_last:
    return list/first([10, 20, 30]) == 10 and list/last([10, 20, 30]) == 30
-- test: test_first_last() == true

fn () bool test_is_empty:
    return list/is_empty([]) == true and list/is_empty([1]) == false
-- test: test_is_empty() == true

-- === std/dict ===

fn () bool test_dict_delete:
    d = {"a": 1, "b": 2}
    removed = dict/delete(d, "a")
    return removed == 1 and len(d) == 1
-- test: test_dict_delete() == true

fn () bool test_dict_merge:
    a = {"x": 1}
    b = {"y": 2, "x": 99}
    dict/merge(a, b)
    return a["x"] == 99 and a["y"] == 2
-- test: test_dict_merge() == true

fn () bool test_dict_get:
    d = {"a": 1}
    return dict/get(d, "a", 0) == 1 and dict/get(d, "z", 42) == 42
-- test: test_dict_get() == true

fn () bool test_dict_has_key:
    d = {"a": 1}
    return dict/has_key(d, "a") == true and dict/has_key(d, "z") == false
-- test: test_dict_has_key() == true

fn () bool test_dict_is_empty:
    return dict/is_empty({}) == true and dict/is_empty({"a": 1}) == false
-- test: test_dict_is_empty() == true

-- === std/os ===

-- test: type(os/time()) == "num"
-- test: type(os/format_time(os/time(), "YYYY-MM-DD")) == "str"

fn () bool test_os_rename:
    os/write("/tmp/_sx_stdlib_test.txt", "ok")
    os/rename("/tmp/_sx_stdlib_test.txt", "/tmp/_sx_stdlib_test2.txt")
    result = os/exists("/tmp/_sx_stdlib_test2.txt")
    os/delete("/tmp/_sx_stdlib_test2.txt")
    return result == true
-- test: test_os_rename() == true
