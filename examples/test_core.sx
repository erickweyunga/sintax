--{
Core language tests.
Run with: sintax test examples/test_core.sx
}--

-- test: add(1, 2) == 3
-- test: add(-5, 5) == 0
-- test: add(0.5, 0.5) == 1
fn (a, b) add:
    a + b

-- test: square(5) == 25
-- test: square(-3) == 9
-- test: square(0) == 0
fn (n) square:
    n * n

-- test: factorial(0) == 1
-- test: factorial(1) == 1
-- test: factorial(5) == 120
-- test: factorial(10) == 3628800
fn (num n) num factorial:
    if n <= 1:
        return 1
    else:
        return n * factorial(n - 1)

-- test: fib(0) == 0
-- test: fib(1) == 1
-- test: fib(10) == 55
fn (num n) num fib:
    if n <= 1:
        return n
    else:
        return fib(n - 1) + fib(n - 2)

-- test: abs_val(-5) == 5
-- test: abs_val(5) == 5
-- test: abs_val(0) == 0
fn (num n) num abs_val:
    if n < 0:
        return -n
    else:
        return n

-- test: is_even(4) == true
-- test: is_even(7) == false
-- test: is_even(0) == true
fn (num n) bool is_even:
    return n % 2 == 0

-- test: greet("World") == "Hello, World!"
-- test: greet("Sintax") == "Hello, Sintax!"
fn (str name) str greet:
    return "Hello, {name}!"

