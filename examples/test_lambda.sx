-- Lambda and functional tests

double = fn(x) -> x * 2
add = fn(a, b) -> a + b

-- test: double(5) == 10
-- test: double(-3) == -6
-- test: add(3, 4) == 7

-- test: [1,2,3].map(fn(x) -> x * 2).len() == 3
-- test: [1,2,3,4].filter(fn(x) -> x > 2).len() == 2
-- test: [1,2,3].reduce(fn(a, x) -> a + x, 0) == 6
-- test: ["a","b","c"].reduce(fn(a, x) -> a + x, "") == "abc"

-- test: [1,2,3].map(fn(x) -> x * 10).filter(fn(x) -> x > 10).len() == 2

is_even = fn(x) -> x % 2 == 0
-- test: is_even(4) == true
-- test: is_even(7) == false
-- test: [1,2,3,4,5,6].filter(is_even).len() == 3
